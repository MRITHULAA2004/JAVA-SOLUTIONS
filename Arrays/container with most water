class Solution {
    public int maxArea(int[] height) {
        
        int i=0;
        int j=height.length-1;
        int maxarea=0;
        while(i<j){
            // area=height*width
            //height=j-i
            //width=min(height[i],height[j])
            int h=j-i;
            int width=Math.min(height[i],height[j]);
            int area =h*width;
            maxarea=Math.max(area,maxarea);

            if(height[i]<height[j]){
                i++;
                }
            else{
                j--;
            }

        }
        return maxarea;
        

        
    }
}
